{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Quick punch + live feed overlay windows",
  "windows": ["quick-punch", "live-feed", "live-feed-*"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "screenshots:default",
    "allow-hide-quick-punch",
    "allow-capture-screenshot",
    "allow-get-desktop-prefs",
    "allow-get-device-auth",
    "allow-clear-device-auth",
    "deep-link:default"
  ]
}
