{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Interstitial Journal",
  "version": "0.1.0",
  "identifier": "com.interstitialjournal.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "quick-punch",
        "title": "Interstitial Journal — Quick Punch",
        "width": 840,
        "height": 580,
        "minWidth": 840,
        "minHeight": 580,
        "maxWidth": 840,
        "maxHeight": 580,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false,
        "focus": true,
        "acceptFirstMouse": true,
        "shadow": false,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["ij"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
